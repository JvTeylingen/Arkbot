# REQUIRED: Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# OPTIONAL: Your bot application's client ID (auto-detected if empty)
CLIENT_ID=123456789012345678

# OPTIONAL: Guild ID for instant command registration (skip for global, 1hr delay)
GUILD_ID=123456789012345678

# OPTIONAL: FTP credentials for death feed log access
FTP_USERNAME=your_ftp_username
FTP_PASSWORD=your_ftp_password

# OPTIONAL: Secret shared between log-watcher and bot webhook
WEBHOOK_SECRET=your_webhook_secret